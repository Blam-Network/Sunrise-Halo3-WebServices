generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["halo3", "odst"]
}

model blind_screenshot {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unique_id             BigInt?
  name                  String   @db.VarChar(16)
  description           String   @db.VarChar(128)
  author                String   @db.VarChar(16)
  file_type             Int
  author_is_xuid_online Boolean
  author_id             BigInt
  size_in_bytes         BigInt
  date                  DateTime @db.Timestamp(6)
  length_seconds        Int
  campaign_id           Int
  map_id                Int
  game_engine_type      Int
  campaign_difficulty   Int
  hopper_id             Int      @db.SmallInt
  game_id               BigInt
  game_tick             Int
  film_tick             Int
  jpeg_length           Int
  camera_position       Float[]
  pixel_width           Int      @db.SmallInt
  pixel_height          Int      @db.SmallInt

  @@unique([unique_id, date, game_id], map: "unique_unique_id_date")
  @@schema("halo3")
}

model carnage_report {
  id                                 String                              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  team_game                          Boolean
  game_id                            BigInt
  map_id                             Int
  scenario_path                      String
  map_variant_name                   String                              @db.VarChar(32)
  game_variant_unique_id             BigInt
  map_variant_unique_id              BigInt
  started                            Boolean
  start_time                         DateTime                            @db.Timestamp(6)
  finished                           Boolean
  finish_time                        DateTime                            @db.Timestamp(6)
  migrated_to_group                  Boolean
  migrated_solo                      Boolean
  simulation_aborted                 Boolean
  in_group_session                   Boolean                             @default(false)
  in_squad_session                   Boolean                             @default(false)
  carnage_report_event_carry         carnage_report_event_carry[]
  carnage_report_event_kill          carnage_report_event_kill[]
  carnage_report_event_score         carnage_report_event_score[]
  carnage_report_game_variant        carnage_report_game_variant?
  carnage_report_machine             carnage_report_machine[]
  carnage_report_matchmaking_options carnage_report_matchmaking_options?
  carnage_report_player              carnage_report_player[]
  carnage_report_player_medals       carnage_report_player_medals[]
  carnage_report_team                carnage_report_team[]

  @@unique([start_time, finish_time, game_id], map: "unique_start_finish_game")
  @@schema("halo3")
}

model carnage_report_event_carry {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  carnage_report_id     String?                @db.Uuid
  time                  BigInt
  carry_player_index    Int                    @db.SmallInt
  position              Float[]
  weapon_index          Int
  carry_type            Int
  carnage_report_player carnage_report_player? @relation(fields: [carnage_report_id, carry_player_index], references: [carnage_report_id, player_index], onDelete: Cascade, onUpdate: NoAction)
  carnage_report        carnage_report?        @relation(fields: [carnage_report_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("halo3")
}

model carnage_report_event_kill {
  id                                                                                                           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  carnage_report_id                                                                                            String?                @db.Uuid
  time                                                                                                         BigInt
  killer_player_index                                                                                          Int                    @db.SmallInt
  dead_player_index                                                                                            Int                    @db.SmallInt
  killer_position                                                                                              Float[]
  dead_position                                                                                                Float[]
  kill_type                                                                                                    Int
  carnage_report_player_carnage_report_event_kill_carnage_report_id_dead_player_indexTocarnage_report_player   carnage_report_player? @relation("carnage_report_event_kill_carnage_report_id_dead_player_indexTocarnage_report_player", fields: [carnage_report_id, dead_player_index], references: [carnage_report_id, player_index], onDelete: Cascade, onUpdate: NoAction)
  carnage_report                                                                                               carnage_report?        @relation(fields: [carnage_report_id], references: [id], onDelete: Cascade)
  carnage_report_player_carnage_report_event_kill_carnage_report_id_killer_player_indexTocarnage_report_player carnage_report_player? @relation("carnage_report_event_kill_carnage_report_id_killer_player_indexTocarnage_report_player", fields: [carnage_report_id, killer_player_index], references: [carnage_report_id, player_index], onDelete: Cascade, onUpdate: NoAction)

  @@schema("halo3")
}

model carnage_report_event_score {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  carnage_report_id     String?                @db.Uuid
  time                  BigInt
  score_player_index    Int                    @db.SmallInt
  position              Float[]
  weapon_index          Int
  score_type            Int
  carnage_report        carnage_report?        @relation(fields: [carnage_report_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  carnage_report_player carnage_report_player? @relation(fields: [carnage_report_id, score_player_index], references: [carnage_report_id, player_index], onDelete: Cascade, onUpdate: NoAction)

  @@schema("halo3")
}

model carnage_report_game_variant {
  id                    String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  game_engine           Int            @db.SmallInt
  unique_id             BigInt
  name                  String         @db.VarChar(16)
  description           String         @db.VarChar(128)
  author                String         @db.VarChar(16)
  file_type             Int
  author_is_xuid_online Boolean
  author_id             BigInt
  size_in_bytes         BigInt
  date                  DateTime       @db.Timestamp(6)
  carnage_report        carnage_report @relation(fields: [id], references: [id], onDelete: Cascade, map: "fk_carnage_report")

  @@schema("halo3")
}

model carnage_report_machine {
  carnage_report_id                               String                  @db.Uuid
  machine_index                                   Int                     @db.SmallInt
  machine_identifier                              Bytes
  machine_exists                                  Boolean?
  machine_connected_to_host                       Boolean?
  machine_host                                    Boolean?
  machine_initial_host                            Boolean?
  machine_voluntary_quit                          Boolean?
  machine_bandwidth_events_0                      Int?
  machine_bandwidth_events_1                      Int?
  machine_bandwidth_events_2                      Int?
  machine_bandwidth_events_3                      Int?
  machine_bandwidth_events_4                      Int?
  session_exists                                  Boolean?
  session_has_hard_drive                          Boolean?
  session_party_nonce                             BigInt?
  session_secure_address                          Bytes?
  session_network_version_number                  Int?
  session_peer_estimated_downstream_bandwidth_bps Int?
  session_peer_estimated_upstream_bandwidth_bps   Int?
  session_peer_nat_type                           Int?
  session_peer_to_peer_connectivity_mask          Int?
  session_peer_to_peer_probed_mask                Int?
  inaddr                                          String?
  inaddr_online                                   String?
  carnage_report                                  carnage_report          @relation(fields: [carnage_report_id], references: [id], onDelete: Cascade, map: "fk_carnage_report")
  carnage_report_player                           carnage_report_player[]

  @@id([carnage_report_id, machine_index])
  @@schema("halo3")
}

model carnage_report_matchmaking_options {
  id                           String         @id(map: "pk_carnage_report_matchmaking_options") @db.Uuid
  hopper_identifier            Int
  hopper_name                  String         @db.VarChar(32)
  hopper_ranked                Boolean
  hopper_team_based            Boolean
  xlast_index                  Int
  draw_probability             BigInt
  beta                         Float
  tau                          Float
  experience_base_increment    BigInt
  experience_penalty_decrement BigInt
  carnage_report               carnage_report @relation(fields: [id], references: [id], onDelete: Cascade)

  @@schema("halo3")
}

