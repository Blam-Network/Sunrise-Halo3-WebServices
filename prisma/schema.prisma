  emblem_secondary_color                                                                                                          Int
  emblem_background_color                                                                                                         Int
  spartan_model_area_0                                                                                                            Int
  spartan_model_area_1                                                                                                            Int
  spartan_model_area_2                                                                                                            Int
  spartan_model_area_3                                                                                                            Int
