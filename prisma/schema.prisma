  is_silver_or_gold_live                                                                                                          Boolean
  is_online_enabled                                                                                                               Boolean
  is_controller_attached                                                                                                          Boolean
  user_selected_team_index                                                                                                        Int
  desires_veto                                                                                                                    Boolean
  desires_rematch                                                                                                                 Boolean
  hopper_access_flags                                                                                                             Int
  is_free_live_gold_account                                                                                                       Boolean
  is_user_created_content_allowed                                                                                                 Boolean
